# Copy this file to .env.local and fill in your keys.
# Next.js loads .env.local automatically — restart the dev server after editing.

# ── Required for AI-powered intent clustering (Mode 2) ───────────────────────
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional: GitHub token ───────────────────────────────────────────────────
# Needed for private repos, or to raise the API rate limit from 60 → 5,000 req/hr.
# Create one at https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=ghp_your-token-here
